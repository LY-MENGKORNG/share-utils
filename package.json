{
  "name": "ts-reusable-utils",
  "private": true,
  "scripts": {
    "build": "bun run --parallel --filter '*' build",
    "dev": "bun run --parallel --env-file=.env.local --filter '*' dev",
    "lint": "bun run --parallel --filter '*' lint",
    "lint:fix": "bun run --parallel --filter '*' lint:fix",
    "fmt": "bun run --parallel --filter '*' fmt",
    "fmt:check": "bun run --parallel --filter '*' fmt:check",
    "check-types": "bun run --parallel --filter '*' check-types",
    "test": "bun run --parallel --filter '*' test",
    "test:watch": "bun run --parallel --filter '*' test:watch",
    "test:coverage": "bun run --parallel --filter '*' test:coverage",
    "test:coverage:watch": "bun run --parallel --filter '*' test:coverage:watch"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "oxfmt": "^0.39.0",
    "oxlint": "^1.53.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
