{
	"name": "ts-reusable-utils",
	"private": true,
	"scripts": {
		"build": "turbo run --parallel build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"fmt": "biome format --write .",
		"typecheck": "turbo run --parallel typecheck",
		"test": "turbo run --parallel test",
		"test:watch": "turbo run --parallel test:watch",
		"test:coverage": "turbo run --parallel test:coverage",
		"test:coverage:watch": "turbo run --parallel test:coverage:watch",
		"clean": "turbo run --parallel clean && rm -rf .turbo"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "^1.3.10",
		"turbo": "^2.8.17",
		"typescript": "5.9.2"
	},
	"packageManager": "bun@1.3.10",
	"engines": {
		"bun": ">=1.3"
	},
	"workspaces": [
		"packages/*",
		"internal/*"
	]
}
