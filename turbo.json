{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:watch": {
      "dependsOn": ["^test:watch"]
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"]
    },
    "test:coverage:watch": {
      "dependsOn": ["^test:coverage:watch"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
